# SPDX-License-Identifier: MIT
# Template for local secrets — copy to .env.local and fill in values
# NEVER commit .env.local (it's gitignored); DO commit this .example

# GitHub fine-grained PAT for this project's repo
# How to create: https://github.com/settings/personal-access-tokens/new
# Required scopes (per v1 Phase 5.5 checklist):
#   - Contents: Read and write
#   - Metadata: Read (auto)
#   - Pull requests: Read and write
#   - Workflows: Read and write
#   - Administration: Read and write  (needed for PATCH repo description / settings via API)
# Resource owner: the target org or user (not default personal account)
# Repository access: All repositories
# Expiration: 90 days recommended
GH_TOKEN=github_pat_PASTE_YOUR_FINE_GRAINED_PAT_HERE

# Add more project-specific secrets below as needed
# SUPABASE_PROJECT_REF=
# SUPABASE_SB_PUBLISHABLE=
# SUPABASE_SB_SECRET=   # DO NOT store service_role here — use Supabase + GitHub Actions secrets instead
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
